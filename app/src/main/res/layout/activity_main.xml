<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  HEADER                                                         -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/gradient_header"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingTop="36dp"
            android:paddingBottom="24dp"
            android:paddingHorizontal="20dp">

            <!-- Mic icon -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎙️"
                android:textSize="40sp" />

            <!-- App name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Smart Mic"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:letterSpacing="0.08"
                android:layout_marginTop="4dp" />

            <!-- Author name — large + gold -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ahmed El-aref"
                android:textColor="#FFD54F"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.05"
                android:layout_marginTop="6dp" />

            <!-- Tagline -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Professional Audio Streaming"
                android:textColor="#99FFFFFF"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  AUDIO LEVEL METER                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <com.ahmedalaref.smartmic.AudioLevelView
            android:id="@+id/audioLevelView"
            android:layout_width="match_parent"
            android:layout_height="@dimen/level_view_height"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp" />

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  INPUT SOURCE CARD                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginVertical="@dimen/card_margin_v"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="#22224A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🎤  Input Source"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/rgInputSource"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbMic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/src_builtin"
                        android:textColor="@color/text_secondary"
                        android:checked="true"
                        android:buttonTint="@color/accent_blue"
                        android:layout_marginBottom="4dp" />

                    <RadioButton
                        android:id="@+id/rbBluetooth"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/src_bluetooth"
                        android:textColor="@color/text_secondary"
                        android:buttonTint="@color/accent_blue"
                        android:layout_marginBottom="4dp" />

                    <RadioButton
                        android:id="@+id/rbWired"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/src_wired"
                        android:textColor="@color/text_secondary"
                        android:buttonTint="@color/accent_blue" />

                </RadioGroup>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  OUTPUT DEVICE CARD                                             -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginVertical="@dimen/card_margin_v"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="#22224A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔊  Output Device"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <RadioGroup
                    android:id="@+id/rgOutputDevice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/rbSpeaker"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/out_speaker"
                        android:textColor="@color/text_secondary"
                        android:checked="true"
                        android:buttonTint="@color/accent_purple"
                        android:layout_marginBottom="4dp" />

                    <RadioButton
                        android:id="@+id/rbBtOut"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/out_bt"
                        android:textColor="@color/text_secondary"
                        android:buttonTint="@color/accent_purple"
                        android:layout_marginBottom="4dp" />

                    <RadioButton
                        android:id="@+id/rbEarpiece"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/out_earpiece"
                        android:textColor="@color/text_secondary"
                        android:buttonTint="@color/accent_purple" />

                </RadioGroup>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  ENHANCEMENTS CARD                                              -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginVertical="@dimen/card_margin_v"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="#22224A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⚡  Enhancements"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/section_title_size"
                    android:textStyle="bold"
                    android:layout_marginBottom="14dp" />

                <!-- Noise Suppression -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Noise Suppression"
                        android:textColor="@color/text_secondary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchNoiseSuppression"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <!-- Auto Gain Control -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Auto Gain Control"
                        android:textColor="@color/text_secondary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchGainControl"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true" />
                </LinearLayout>

                <!-- Push-to-Talk -->
                <LinearLayout android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Push-to-Talk mode"
                        android:textColor="@color/text_secondary" />
                    <com.google.android.material.switchmaterial.SwitchMaterial
                        android:id="@+id/switchPushToTalk"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="false" />
                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  CONTROL BUTTONS                                                -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginVertical="@dimen/card_margin_v"
            android:gravity="center">

            <Button
                android:id="@+id/btnStream"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height"
                android:layout_weight="1"
                android:text="▶  Start"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/accent_blue"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btnRecord"
                android:layout_width="0dp"
                android:layout_height="@dimen/btn_height"
                android:layout_weight="1"
                android:text="⏺  Record"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/accent_coral"
                android:enabled="false"
                style="@style/Widget.MaterialComponents.Button" />

        </LinearLayout>

        <!-- Status line -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Idle"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginHorizontal="16dp"
            android:layout_marginBottom="4dp" />

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  RECORDINGS LIST CARD                                           -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/card_margin_h"
            android:layout_marginVertical="@dimen/card_margin_v"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="@dimen/card_elevation"
            app:strokeColor="#22224A"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/card_padding">

                <!-- Section header row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="📁  Recordings"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/section_title_size"
                        android:textStyle="bold" />

                    <!-- Refresh button -->
                    <Button
                        android:id="@+id/btnRefresh"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="↻"
                        android:textSize="18sp"
                        android:textColor="@color/accent_blue"
                        android:padding="0dp"
                        style="@style/Widget.MaterialComponents.Button.TextButton" />

                </LinearLayout>

                <!-- Empty state -->
                <TextView
                    android:id="@+id/tvNoRecordings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No recordings yet.\nStart streaming and hit ⏺ Record."
                    android:textColor="@color/text_hint"
                    android:textSize="13sp"
                    android:gravity="center"
                    android:padding="16dp"
                    android:visibility="visible" />

                <!-- List -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecordings"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:visibility="gone" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!--  FOOTER                                                          -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="All rights reserved Ahmed El-aref"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:gravity="center"
            android:paddingVertical="20dp" />

    </LinearLayout>

</ScrollView>
