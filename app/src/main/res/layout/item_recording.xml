<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_recording_item"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Top row: icon + name -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎵"
                android:textSize="22sp"
                android:layout_marginEnd="10dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <!-- File name — bound as b.tvFileName -->
                <TextView
                    android:id="@+id/tvFileName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <!-- Date + size row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="2dp">

                    <!-- Date — bound as b.tvFileDate -->
                    <TextView
                        android:id="@+id/tvFileDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="  •  "
                        android:textColor="@color/text_hint"
                        android:textSize="12sp" />

                    <!-- File size — bound as b.tvFileSize -->
                    <TextView
                        android:id="@+id/tvFileSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/accent_blue"
                        android:textSize="12sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Play / Stop toggle — bound as b.btnPlay -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlay"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="▶"
                android:textSize="16sp"
                app:backgroundTint="@color/accent_purple"
                app:cornerRadius="21dp"
                android:layout_marginStart="6dp" />

            <!-- Delete — bound as b.btnDelete -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDelete"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:text="🗑"
                android:textSize="16sp"
                app:backgroundTint="@color/accent_red"
                app:cornerRadius="21dp"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
